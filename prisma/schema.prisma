generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Fornecedor {
  id           Int         @id @default(autoincrement())
  razao_social String      @db.VarChar(40)
  entradas     Entrada[]
  deleted      Boolean     @default(false)
  deletedAt    DateTime?
  @@map("fornecedores")
}

model Secretaria {
  id           Int         @id @default(autoincrement())
  nome         String      @db.VarChar(40)
  saidas       Saida[]     
  deleted      Boolean     @default(false)
  deletedAt    DateTime?
  @@map("secretarias")
}

model Produto {
  id           Int        @id @default(autoincrement())
  nome         String     @db.VarChar(60) 
  quant        Int        @db.SmallInt
  preco        Decimal    @db.Decimal(9,2)
  categoria    String     @db.VarChar(40)
  saidas       Saida[]
  entradas     Entrada[]
  deleted      Boolean     @default(false)
  deletedAt    DateTime?
  @@map("produtos")
}

model Entrada {
  id         Int        @id @default(autoincrement())
  data       DateTime   @default(now())
  numDocumento  Int?     
  fornecedor Fornecedor @relation(fields: [fornecedorId], references: [id])
  fornecedorId Int
  produto    Produto    @relation(fields: [produtoId], references: [id])
  produtoId  Int
  quant      Int
  observacoes String?   @db.VarChar(60)
  deleted      Boolean     @default(false)
  deletedAt    DateTime?
  @@map("entradas")
}

model Saida {
  id         Int        @id @default(autoincrement())
  data       DateTime   @default(now())
  secretaria Secretaria @relation(fields: [secretariaId], references: [id])
  secretariaId Int
  produto    Produto    @relation(fields: [produtoId], references: [id])
  produtoId  Int
  quant      Int
  observacoes String?   @db.VarChar(60)
  deleted      Boolean     @default(false)
  deletedAt    DateTime?
  @@map("saidas")
}

model Usuario {
  id                Int         @id @default(autoincrement())
  nome              String      @db.VarChar(50)
  email             String      @db.VarChar(100) @unique()
  senha             String      @db.VarChar(60)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt()
  codRecuperacao    String?     @db.VarChar(4)
  ultimoLogin       DateTime?   
  log               Log[]
  nivel             Int         @default(1)
  deleted           Boolean     @default(false)
  deletedAt         DateTime?
  tentativasFalhas  Int         @default(0)
  bloqueado         Boolean     @default(false)
  status            String      @default("INATIVO")
  codAtivacao       String?     @db.Char(4)
  @@map("usuarios")
}

model Log {
  id          Int         @id @default(autoincrement())
  descricao   String      @db.VarChar(255)
  complemento String      @db.Text
  createdAt   DateTime    @default(now())
  usuario     Usuario     @relation(fields: [usuarioId], references: [id])
  usuarioId   Int
  @@map("logs")
}

model TokenListaBloqueio {
  id          Int         @id @default(autoincrement())
  token       String      @db.VarChar(500)
  usuarioId   Int
  expiresAt   DateTime?   @default(now())
  @@map("tokens")
}